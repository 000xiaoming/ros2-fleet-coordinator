<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="fleet_demo">
    <include>
      <uri>model://ground_plane</uri>
    </include>
    <include>
      <uri>model://sun</uri>
    </include>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.15 0.18 0.2 1</background>
      <shadows>false</shadows>
    </scene>

    <physics type="ode">
      <max_step_size>0.01</max_step_size>
      <real_time_update_rate>100.0</real_time_update_rate>
    </physics>
  </world>
</sdf>
